# ─────────────────────────────────────────────────────────────────────────────
# Operation Honor — Environment Variables
#
# 1. Copy this file:  cp .env.local.example .env.local
# 2. Fill in your values from https://sanity.io/manage
# 3. Restart the dev server after any changes
# ─────────────────────────────────────────────────────────────────────────────

# ── Sanity project (required) ─────────────────────────────────────────────────
# Found in Sanity Manage → your project → Settings → API
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# ── Sanity API token (optional — only needed for draft/preview mode) ──────────
# Create a token in Sanity Manage → your project → Settings → API → Tokens
# Use "Viewer" role for read-only access, "Editor" for draft previews
SANITY_API_TOKEN=

# ── On-demand revalidation secret (optional) ─────────────────────────────────
# Set this to a long random string, then use it in your Sanity webhook payload
# to trigger revalidation at /api/revalidate
SANITY_REVALIDATE_SECRET=
